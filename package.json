{
  "name": "align-everyday",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "expo:check": "expo install --check",
    "build": "expo export --platform web",
    "build:e2e": "EXPO_PUBLIC_E2E=true EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 EXPO_PUBLIC_SUPABASE_ANON_KEY=e2e-anon-key expo export --clear --platform web",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:lint": "supabase db lint --local --level error"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~56.0.12",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.4",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-refresh": "0.14.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  }
}
