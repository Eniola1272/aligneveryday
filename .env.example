EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional until a Sentry project is created. Monitoring remains disabled without a DSN.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=development

# Build-time source map upload values. Keep the auth token secret and never use EXPO_PUBLIC_.
SENTRY_ORG=your-sentry-organization
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-secret-source-map-token

# Google credentials remain in Google Cloud and Supabase Auth, never in the Expo app.
# Add aligneveryday://onboarding and your web /onboarding URL to Supabase Redirect URLs.

# Local Codex product-planning automation only. Never expose with EXPO_PUBLIC_.
CLICKUP_API_TOKEN=your-rotated-clickup-token
